<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Square Webhook Queue Tree View -->
    <record id="view_square_webhook_queue_tree" model="ir.ui.view">
        <field name="name">square.webhook.queue.tree</field>
        <field name="model">square.webhook.queue</field>
        <field name="arch" type="xml">
            <tree string="Webhook Queue"
                decoration-success="state == 'completed'"
                decoration-warning="state == 'pending'"
                decoration-danger="state in ['failed', 'expired']"
                decoration-muted="state == 'processing'">
                <field name="create_date" string="Queued At" />
                <field name="event_type" string="Event Type" />
                <field name="square_order_id" string="Order ID" />
                <field name="order_version" string="Version" />
                <field name="retry_count" string="Retries" />
                <field name="next_retry_time" string="Next Retry" />
                <field name="state" widget="badge" />
                <field name="processed_at" string="Processed At" optional="hide" />
            </tree>
        </field>
    </record>

    <!-- Square Webhook Queue Form View -->
    <record id="view_square_webhook_queue_form" model="ir.ui.view">
        <field name="name">square.webhook.queue.form</field>
        <field name="model">square.webhook.queue</field>
        <field name="arch" type="xml">
            <form string="Webhook Queue Entry" create="false">
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="pending,processing,completed" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="event_type" readonly="1" />
                        </h1>
                        <h2>
                            <field name="webhook_event_id" readonly="1" />
                        </h2>
                    </div>

                    <group>
                        <group string="Event Information">
                            <field name="create_date" string="Queued At" />
                            <field name="square_order_id" />
                            <field name="order_version" />
                            <field name="depends_on_order" />
                        </group>
                        <group string="Retry Status">
                            <field name="retry_count" />
                            <field name="max_retries" />
                            <field name="next_retry_time" />
                            <field name="processed_at" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Order Data" name="order_data">
                            <field name="order_data" readonly="1" widget="text" />
                        </page>
                        <page string="Error Message" name="error" invisible="not error_message">
                            <field name="error_message" readonly="1" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Square Webhook Queue Search View -->
    <record id="view_square_webhook_queue_search" model="ir.ui.view">
        <field name="name">square.webhook.queue.search</field>
        <field name="model">square.webhook.queue</field>
        <field name="arch" type="xml">
            <search string="Webhook Queue">
                <field name="webhook_event_id" string="Event ID"
                    filter_domain="[('webhook_event_id', 'ilike', self)]" />
                <field name="square_order_id" string="Order ID"
                    filter_domain="[('square_order_id', 'ilike', self)]" />
                <field name="event_type" string="Event Type" />

                <separator />
                <filter name="filter_pending" string="Pending" domain="[('state', '=', 'pending')]" />
                <filter name="filter_processing" string="Processing"
                    domain="[('state', '=', 'processing')]" />
                <filter name="filter_failed" string="Failed" domain="[('state', '=', 'failed')]" />
                <filter name="filter_expired" string="Expired" domain="[('state', '=', 'expired')]" />
                <filter name="filter_completed" string="Completed"
                    domain="[('state', '=', 'completed')]" />

                <separator />
                <filter name="filter_ready_for_retry" string="Ready for Retry"
                    domain="[('state', '=', 'pending'), ('next_retry_time', '&lt;=', context_today().strftime('%Y-%m-%d %H:%M:%S'))]" />

                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by': 'state'}" />
                    <filter name="group_event_type" string="Event Type"
                        context="{'group_by': 'event_type'}" />
                    <filter name="group_order" string="Order ID"
                        context="{'group_by': 'square_order_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Square Webhook Queue Action -->
    <record id="action_square_webhook_queue" model="ir.actions.act_window">
        <field name="name">Webhook Queue</field>
        <field name="res_model">square.webhook.queue</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{
            'search_default_filter_pending': 1,
            }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No queued webhook events
            </p>
            <p>
                This queue stores webhook events that arrived out of order and need to be retried.
                Events are automatically processed by a scheduled job.
            </p>
        </field>
    </record>

    <!-- Add to Square Menu -->
    <menuitem id="menu_square_webhook_queue"
        name="Webhook Queue"
        parent="menu_square_main"
        action="action_square_webhook_queue"
        sequence="35" />
</odoo>
