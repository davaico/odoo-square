<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Square Integration Bot User -->
    <record id="user_square_bot" model="res.users">
        <field name="name">Square Integration Bot</field>
        <field name="login">square_bot</field>
        <field name="email">square-bot@example.com</field>
        <field name="active">True</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('base.group_user'),
            ref('sales_team.group_sale_salesman'),
            ref('sales_team.group_sale_manager'),
            ref('account.group_account_invoice'),
            ref('stock.group_stock_manager')
        ])]"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="company_ids" eval="[(6, 0, [ref('base.main_company')])]"/>
    </record>

    <!-- Partner for Square Bot -->
    <record id="partner_square_bot" model="res.partner">
        <field name="name">Square Integration Bot</field>
        <field name="email">square-bot@example.com</field>
        <field name="is_company">False</field>
        <field name="supplier_rank">0</field>
        <field name="customer_rank">0</field>
    </record>

    <!-- Link partner to user -->
    <record id="user_square_bot" model="res.users">
        <field name="partner_id" ref="partner_square_bot"/>
    </record>
</odoo>
